# Database
DATABASE_URL=postgresql+asyncpg://music_corn:music_corn@localhost:5433/music_corn

# Anthropic (for music extraction + script writing)
ANTHROPIC_API_KEY=

# OpenAI (for Whisper transcription + TTS)
OPENAI_API_KEY=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Podcast
TTS_VOICE=nova
PODCAST_OUTPUT_DIR=./output/podcasts

# Scheduling
INGEST_INTERVAL_HOURS=6
WEEKLY_PIPELINE_DAY=mon
WEEKLY_PIPELINE_HOUR=6

# Logging
LOG_LEVEL=INFO
